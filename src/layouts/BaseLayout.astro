---
import "../styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { localBusinessSchema, site, titleFor } from "@/data/site";

type Props = {
  title?: string;
  description: string;
  pathname?: string;
  robots?: string;
};

const pathname = Astro.props.pathname ?? (Astro.url.pathname.replace(/\/$/, "") || "/");
const pageTitle = Astro.props.title ?? titleFor(pathname);
const canonical = `${site.url}${pathname === "/" ? "/" : `${pathname}/`}`;
const schema = JSON.stringify(localBusinessSchema());
const robots = Astro.props.robots ?? "index, follow";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/assets/logo.png" type="image/png" />
    <title>{pageTitle}</title>
    <meta name="description" content={Astro.props.description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={Astro.props.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={schema}></script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
