---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Thank You | Advanced Carpets & Restoration" description="Thanks for contacting Advanced Carpets & Restoration." pathname="/thank-you">
  <section class="section section-white">
    <div class="container thank-you-panel">
      <h1>Thanks, we've got your enquiry</h1>
      <p class="copy">The team will review the job details and get back to you with the next practical step.</p>
      <p><a class="button button-dark" href="/">Back home</a></p>
    </div>
  </section>
</BaseLayout>
