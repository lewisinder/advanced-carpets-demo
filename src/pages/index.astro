---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HomePage from "@/components/tina/HomePage.astro";
import TinaIsland from "@tinacms/astro/TinaIsland.astro";
import { islands } from "@/lib/tina/islands";
import { home as staticHome, type HomeContent } from "@/data/home";

// The GitHub Pages build is fully static with no Tina backend, so read the home
// content straight from JSON. On dev/Netlify (base "/") we use the Tina client
// and island wrapper so live visual editing keeps working.
const isGithubPages = import.meta.env.BASE_URL !== "/";

let home: HomeContent;
if (isGithubPages) {
  home = staticHome;
} else {
  const { getHome } = await import("@/lib/tina/data");
  const response = await getHome();
  home = response.data.home as unknown as HomeContent;
}
---

<BaseLayout description={home.seoDescription} pathname="/">
  {isGithubPages ? (
    <HomePage home={home} />
  ) : (
    <TinaIsland name="home" wrapper={islands.home.wrapper} primary>
      <HomePage home={home} />
    </TinaIsland>
  )}
</BaseLayout>
