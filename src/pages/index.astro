---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BeforeAfter from "@/components/BeforeAfter.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import CTA from "@/components/CTA.astro";
import ContactForm from "@/components/ContactForm.astro";
import { services } from "@/data/services";
import { site } from "@/data/site";

const primaryServices = services.slice(0, 4);
const secondaryServices = services.slice(4);
const reviews = [
  {
    name: "Jess Matthews",
    time: "Google review",
    initials: "JM",
    avatar: "#4285f4",
    text: "Superb job everytime. Highly recommend. We had our couches, carpets and tiles cleaned while at work and came home to the cleanest home I've ever seen.",
  },
  {
    name: "Mark Sinclair",
    time: "Google review",
    initials: "MS",
    avatar: "#34a853",
    text: "Used Advanced Carpets after a water leak in our hallway. Fast response, professional gear, and the carpet dried out perfectly.",
  },
  {
    name: "Jo Blackwell",
    time: "Google review",
    initials: "JB",
    avatar: "#ea4335",
    text: "Had the upholstery done on our couch and two armchairs. Came up looking brand new. Great service from a friendly local operator.",
  },
];
const faqs = [
  ["What areas do you service?", "Cromwell, Alexandra, Queenstown, Wanaka, and the wider Central Otago and Southern Lakes region."],
  ["How long does carpet cleaning take to dry?", "Most carpets are dry within a few hours under normal conditions. Good airflow helps speed this up."],
  ["Can you treat pet stains and odours?", "Yes. Pet marks and odours can be assessed and treated with a targeted approach."],
  ["Do I need to move furniture before you arrive?", "Move smaller items where practical. Larger items can be discussed when booking."],
  ["How quickly can you respond to flood or water damage?", "Call directly for urgent jobs. Fast action is important with water damage."],
];
---

<BaseLayout description="Professional carpet cleaning, upholstery care, stain treatment, repairs, and restoration across Central Otago and the Southern Lakes." pathname="/">
  <section class="hero">
    <video class="hero-video" autoplay muted loop playsinline>
      <source src="/assets/header.webm" type="video/webm" />
      <source src="/assets/header.mp4" type="video/mp4" />
    </video>
    <div class="container">
      <div class="hero-content">
        <h1>Carpet Cleaning &amp; Restoration Across Central Otago and the Southern Lakes</h1>
        <p>Carpets, upholstery, stains, repairs, hard floors, and urgent water damage handled with proper equipment and practical local service.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/contact">Make an enquiry</a>
          <a class="button button-outline" href="/services">View services</a>
        </div>
        <div class="hero-proof">
          <div class="review-line">
            <span class="hero-stars">★★★★★</span>
            <strong>4.8</strong>
            <span>94 Google reviews</span>
          </div>
          <div class="trusted-line">
            <span>Trusted by</span>
            <strong>IICRC</strong>
            <strong>Master Cleaners NZ</strong>
            <strong>Queenstown Chamber</strong>
            <strong>Central Otago Business</strong>
          </div>
        </div>
        <div class="hero-metrics">
          <div>
            <strong>7 Days</strong>
            <span>Cleaning and urgent response enquiries</span>
          </div>
          <div>
            <strong>6,000+</strong>
            <span>Cleaning jobs completed</span>
          </div>
          <div>
            <strong>IICRC</strong>
            <span>Certified technicians</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <div class="section-heading">
        <h2>Core cleaning and restoration services</h2>
        <p>Start with the work customers most often need at home, in rentals, and across commercial spaces.</p>
      </div>
      <div class="grid grid-4">
        {primaryServices.map((service) => <ServiceCard service={service} />)}
      </div>
      <div class="also-services">
        <p>Also available</p>
        <div class="also-services-grid">
          {secondaryServices.map((service) => <ServiceCard service={service} compact />)}
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <div class="section-heading">
        <p class="overline">Results</p>
        <h2>Before &amp; after</h2>
        <p>Drag the handle to compare. Real job imagery can replace these placeholders once final photos are chosen.</p>
      </div>
      <div class="ba-gallery">
        <BeforeAfter
          beforeSrc="/assets/gutter-before.jpeg"
          afterSrc="/assets/gutter-after.jpeg"
          beforeAlt="Gutter before clearing"
          afterAlt="Gutter after clearing"
          label="Gutter clean"
        />
        <BeforeAfter
          beforeSrc="/assets/carpet-extraction.jpg"
          afterSrc="/assets/carpet-extraction.jpg"
          beforeAlt="Upholstery before cleaning"
          afterAlt="Upholstery after cleaning"
          label="Upholstery clean"
        />
        <BeforeAfter
          beforeSrc="/assets/hero-cleaning.png"
          afterSrc="/assets/hero-cleaning.png"
          beforeAlt="Carpet before cleaning"
          afterAlt="Carpet after cleaning"
          label="Carpet clean"
        />
      </div>
    </div>
  </section>

  <section class="section section-white reviews-section">
    <div class="container reviews-layout">
      <div>
        <p class="google-label"><img src="/assets/google-g.svg" alt="" /> <span>Google Reviews</span></p>
        <h2>What customers say about us</h2>
        <div class="rating-lockup">
          <span class="stars">★★★★★</span>
          <strong>4.8</strong>
          <small>based on 94 reviews</small>
        </div>
      </div>
      <div class="review-grid">
        {reviews.map((review) => (
          <article class="review-card">
            <div class="review-card-head">
              <span class="review-avatar" style={`--avatar:${review.avatar}`}>{review.initials}</span>
              <div>
                <strong>{review.name}</strong>
                <span>{review.time}</span>
              </div>
              <img class="google-mark" src="/assets/google-g.svg" alt="" />
            </div>
            <p class="stars">★★★★★</p>
            <p>{review.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-dark trust-section">
    <div class="container trust-layout">
      <div>
        <p class="overline orange">Why Advanced Carpets</p>
        <h2>Straightforward service from trained local technicians</h2>
        <p>Clear service areas, practical quoting, visible equipment, and trained restoration experience are stronger than broad marketing claims.</p>
      </div>
      <div class="trust-list">
        <div>
          <h3>Local coverage</h3>
          <p>Cromwell, Alexandra, Queenstown, Wanaka, Central Otago, and the Southern Lakes.</p>
        </div>
        <div>
          <h3>Trained technicians</h3>
          <p>IICRC training and practical restoration experience can sit as a credibility point.</p>
        </div>
        <div>
          <h3>Cleaning + restoration</h3>
          <p>Carpet, upholstery, stain, flood, repair, hard floor, solar, gutter, and pest support.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container about-preview">
      <div class="media-block">
        <img src="/assets/hero-cleaning.png" alt="Carpet cleaning equipment in a bright room" />
        <p>Room-scale cleaning work with equipment visible and the carpet surface easy to inspect.</p>
        <div class="stat-badge">
          <strong>6,000+</strong>
          <span>Jobs completed</span>
        </div>
      </div>
      <div>
        <p class="overline">About us</p>
        <h2>Local people, proper gear, honest work</h2>
        <p class="copy">Advanced Carpets has been serving Central Otago and the Southern Lakes with reliable cleaning, restoration, and practical property support.</p>
        <p class="copy">Based around Cromwell and covering Alexandra, Queenstown, Wanaka, and the wider region, the site keeps local contact details and service expectations easy to find.</p>
        <div class="inline-actions">
          <a class="button button-dark" href="/about">Meet the team</a>
          <div class="rating-lockup">
            <span class="stars">★★★★★</span>
            <strong>4.8</strong>
            <small>on Google</small>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <h2>Built around the areas already serviced</h2>
        <p>The main towns are easy to find, with wider Central Otago and Southern Lakes coverage handled through direct enquiries.</p>
      </div>
      <div class="grid grid-4">
        {site.phones.map((phone) => (
          <div class="panel">
            <h3>{phone.label}</h3>
            <p>{phone.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container">
      <div class="section-heading compact-heading">
        <h2>Getting booked in 4 simple steps</h2>
      </div>
      <div class="steps-grid">
        <article>
          <span>1</span>
          <h3>Fill out our form</h3>
          <p>Share your address, job description, and any photos to help us understand the work needed.</p>
        </article>
        <article>
          <span>2</span>
          <h3>We check the details</h3>
          <p>We'll assess your request and send back a clear, practical response.</p>
        </article>
        <article>
          <span>3</span>
          <h3>Book a time that suits</h3>
          <p>Pick a day and time that works for you across Central Otago and the Southern Lakes.</p>
        </article>
        <article>
          <span>4</span>
          <h3>We come to you</h3>
          <p>Your technician arrives ready to work, handles the job, and leaves the space clean.</p>
        </article>
      <div class="steps-cta">
        <a class="button button-primary" href="/contact">Fill out the form</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container enquiry-panel">
      <div>
        <p class="overline orange">Contact Us</p>
        <h2>Tell us what needs cleaning or restoring</h2>
        <p>Send the room, material, stain, damage, access notes, and photos if they help. The team can respond with practical next steps.</p>
        <div class="contact-lines">
          {site.phones.map((phone) => <span>{phone.label} &nbsp; {phone.value}</span>)}
          <span>{site.email}</span>
        </div>
      </div>
      <div class="form-shell">
        <ContactForm />
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container faq-layout">
      <div>
        <p class="overline">FAQ</p>
        <h2>Common questions</h2>
        <p class="copy">Can't find what you're looking for? Get in touch and we'll answer directly.</p>
        <a href="/contact">Make an enquiry</a>
      </div>
      <div class="faq-list">
        {faqs.map(([question, answer]) => (
          <details>
            <summary>{question}<span>+</span></summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
