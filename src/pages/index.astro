---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HomePage from "@/components/tina/HomePage.astro";
import TinaIsland from "@tinacms/astro/TinaIsland.astro";
import { getHome } from "@/lib/tina/data";
import { islands } from "@/lib/tina/islands";
import type { HomeContent } from "@/data/home";

const response = await getHome();
const home = response.data.home as unknown as HomeContent;
---

<BaseLayout description={home.seoDescription} pathname="/">
  <TinaIsland name="home" wrapper={islands.home.wrapper} primary>
    <HomePage home={home} />
  </TinaIsland>
</BaseLayout>
